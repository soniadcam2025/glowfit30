generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  super_admin
  admin
  user
}

model User {
  id           String    @id @default(uuid()) @db.Uuid
  name         String
  email        String    @unique
  password     String?
  role         UserRole  @default(user)
  isBlocked    Boolean   @default(false) @map("is_blocked")
  createdAt    DateTime  @default(now()) @map("created_at")

  // Firebase / social login fields
  firebaseUid  String?   @unique @map("firebase_uid")
  photoUrl     String?   @map("photo_url")

  // Push notification token
  fcmToken     String?   @map("fcm_token")

  // Onboarding profile fields
  fitnessLevel String?   @map("fitness_level")
  goal         String?   @map("goal")
  dietStyle    String?   @map("diet_style")
  targetWeight Float?    @map("target_weight")
  focusAreas   String[]  @map("focus_areas")
  dob          DateTime? @map("dob")
  height       Float?    @map("height")
  weight       Float?    @map("weight")

  adminLogs    AdminLog[]
  progress     Progress[]

  @@map("users")
}

model Workout {
  id          String       @id @default(uuid()) @db.Uuid
  title       String
  level       String
  duration    Int
  imageUrl    String?      @map("image_url")
  description String?      @db.Text
  goal        String?
  createdAt   DateTime     @default(now()) @map("created_at")

  days        WorkoutDay[]

  @@map("workouts")
}

model WorkoutDay {
  id         String     @id @default(uuid()) @db.Uuid
  workoutId  String     @map("workout_id") @db.Uuid
  workout    Workout    @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  dayNumber  Int        @map("day_number")
  title      String
  focus      String?
  createdAt  DateTime   @default(now()) @map("created_at")

  exercises  Exercise[]
  progress   Progress[]

  @@index([workoutId])
  @@map("workout_days")
}

model Exercise {
  id           String     @id @default(uuid()) @db.Uuid
  workoutDayId String     @map("workout_day_id") @db.Uuid
  workoutDay   WorkoutDay @relation(fields: [workoutDayId], references: [id], onDelete: Cascade)
  name         String
  sets         Int?
  reps         Int?
  duration     Int?
  rest         Int?
  imageUrl     String?    @map("image_url")
  gifUrl       String?    @map("gif_url")
  videoUrl     String?    @map("video_url")
  order        Int        @default(0)
  createdAt    DateTime   @default(now()) @map("created_at")

  @@index([workoutDayId])
  @@map("exercises")
}

model Progress {
  id           String     @id @default(uuid()) @db.Uuid
  userId       String     @map("user_id") @db.Uuid
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  workoutDayId String     @map("workout_day_id") @db.Uuid
  workoutDay   WorkoutDay @relation(fields: [workoutDayId], references: [id], onDelete: Cascade)
  completedAt  DateTime   @default(now()) @map("completed_at")
  caloriesBurned Int?     @map("calories_burned")
  durationMin  Int?       @map("duration_min")

  @@unique([userId, workoutDayId])
  @@index([userId])
  @@map("progress")
}

model DietPlan {
  id        String   @id @default(uuid()) @db.Uuid
  type      String
  calories  Int
  meals     Json
  imageUrl  String?  @map("image_url")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("diet_plans")
}

model BeautyPost {
  id        String   @id @default(uuid()) @db.Uuid
  title     String
  content   String   @db.Text
  imageUrl  String?  @map("image_url")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("beauty_posts")
}

model AdminLog {
  id        String   @id @default(uuid()) @db.Uuid
  adminId   String   @map("admin_id") @db.Uuid
  admin     User     @relation(fields: [adminId], references: [id], onDelete: Cascade)
  action    String
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([adminId])
  @@map("admin_logs")
}
