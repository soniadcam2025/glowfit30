NODE_ENV=production
PORT=3000
DATABASE_URL=postgresql://user:password@127.0.0.1:5432/glowfit_db
# If using SSH tunnel on local machine:
# DATABASE_URL=postgresql://user:password@127.0.0.1:5433/glowfit_db
JWT_SECRET=replace_with_strong_secret_min_16_chars
REDIS_URL=redis://127.0.0.1:6379

# Optional but recommended
JWT_EXPIRES_IN=7d
CORS_ORIGINS=https://admin.glowfit30.com,http://localhost:3001
AUTH_COOKIE_NAME=token
AUTH_DEBUG=false
REGISTER_ENABLED=false
